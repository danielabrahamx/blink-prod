{
  "name": "blink",
  "version": "0.1.0-dev",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "electron"
  ],
  "scripts": {
    "test": "npx hardhat test",
    "test:contract": "npx hardhat test",
    "test:settlement": "cd backend && npm test",
    "test:auto-signer": "cd electron && npm test",
    "test:all": "npm run test:contract && npm run test:settlement && npm run test:auto-signer",
    "compile": "npx hardhat compile",
    "typecheck": "cd backend && npm run typecheck && cd ../electron && npm run typecheck",
    "deploy:blink-reserve": "npx hardhat run scripts/deploy-blink-reserve.js --network arc_testnet",
    "deploy:blink-reserve:local": "npx hardhat run scripts/deploy-blink-reserve.js --network hardhat",
    "export:abi": "node scripts/export-blink-reserve-abi.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:api": "playwright test tests/e2e/api.spec.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "Blink - per-second laptop micro-insurance on Arc testnet",
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts": "^5.0.2",
    "@playwright/test": "^1.58.2",
    "dotenv": "^16.5.0",
    "ethers": "^6.14.0",
    "hardhat": "^2.24.0"
  },
  "dependencies": {
    "@chainlink/contracts": "^1.2.0"
  }
}
