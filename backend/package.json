{
  "name": "blink-backend",
  "version": "0.1.0-dev",
  "description": "Backend service for Blink per-second laptop micro-insurance with x402 nanopayments",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "node src/db/migrate.cjs"
  },
  "dependencies": {
    "@circle-fin/developer-controlled-wallets": "^9.2.0",
    "@circlefin/x402-batching": "^1.0.5",
    "@x402/core": "^2.5.0",
    "@x402/evm": "^2.5.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "ethers": "^6.9.0",
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "viem": "^2.46.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.11.0",
    "@types/supertest": "^6.0.2",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.4",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
