{
  "name": "blink-backend",
  "version": "0.2.0-dev",
  "description": "Backend service for Blink per-second laptop micro-insurance with x402 nanopayments",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:migrations": "vitest run migrations/migrations.test.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "migrate:up": "bun run scripts/migrate.ts up",
    "migrate:down": "bun run scripts/migrate.ts down",
    "migrate:status": "bun run scripts/migrate.ts status",
    "migrate:create": "bun run scripts/migrate.ts create",
    "db:seed": "bun run scripts/migrate.ts seed",
    "migrate:settlement": "node src/db/migrate.cjs",
    "legacy:start": "node server.js"
  },
  "dependencies": {
    "@x402/core": "^2.5.0",
    "@x402/evm": "^2.5.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "ethers": "^6.9.0",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "maxmind": "^5.0.6",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.13.0",
    "pino": "^9.3.2",
    "pino-http": "^10.2.0",
    "viem": "^2.46.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^10.13.2",
    "@types/bun": "^1.3.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.9.0",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^8.57.0",
    "ioredis-mock": "^8.9.0",
    "node-pg-migrate": "^7.6.1",
    "nodemon": "^3.0.2",
    "pino-pretty": "^11.2.1",
    "supertest": "^7.0.0",
    "testcontainers": "^10.13.2",
    "tsx": "^4.16.2",
    "typescript": "^5.6.3",
    "vitest": "^1.6.0"
  },
  "optionalDependencies": {
    "@circle-fin/developer-controlled-wallets": "^9.2.0",
    "@circlefin/x402-batching": "^1.0.5"
  }
}
